# RESEND_API_KEY: Required for sending contact form submissions.
RESEND_API_KEY="re_xxxxxxxxx"

# CONTACT_FORM_FROM: Must be a sender verified in your Resend account.
CONTACT_FORM_FROM="Agenzion Contact <info@agenzion.com>"

# CONTACT_FORM_TO: Inbox for contact form messages. Defaults to info@agenzion.com if omitted.
CONTACT_FORM_TO="info@agenzion.com"
