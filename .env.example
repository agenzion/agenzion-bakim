# RESEND_API_KEY: Required for sending contact form submissions.
RESEND_API_KEY="re_xxxxxxxxx"

# CONTACT_FORM_FROM: Must be a sender verified in your Resend account.
CONTACT_FORM_FROM="Agenzion Contact <info@agenzion.com>"

# CONTACT_FORM_TO: Inbox for contact form messages. Defaults to info@agenzion.com if omitted.
CONTACT_FORM_TO="info@agenzion.com"

# Public Sanity Content Lake connection used by the website.
NEXT_PUBLIC_SANITY_PROJECT_ID="03ibs86g"
NEXT_PUBLIC_SANITY_DATASET="production"
NEXT_PUBLIC_SANITY_API_VERSION="2026-04-20"

# Optional: set this only if the dataset is private or draft preview reads are needed.
SANITY_API_READ_TOKEN=""
