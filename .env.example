# SMTP settings for sending contact form submissions.
CONTACT_SMTP_HOST="smtp.hostinger.com"
CONTACT_SMTP_PORT="465"
CONTACT_SMTP_SECURE="true"
CONTACT_SMTP_USER="studio@agenzion.com"
CONTACT_SMTP_PASS="change-me"

# Contact form sender and recipient.
CONTACT_FORM_FROM="Agenzion Web Studio <studio@agenzion.com>"
CONTACT_FORM_TO="studio@agenzion.com"

# Public Sanity Content Lake connection used by the website.
NEXT_PUBLIC_SANITY_PROJECT_ID="03ibs86g"
NEXT_PUBLIC_SANITY_DATASET="production"
NEXT_PUBLIC_SANITY_API_VERSION="2026-04-20"

# Optional: set this only if the dataset is private or draft preview reads are needed.
SANITY_API_READ_TOKEN=""
